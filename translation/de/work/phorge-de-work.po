#, php-format
msgid ""
"The URI protocol is unrecognized. It should begin with \"%s\", \"%s\", "
"\"%s\", \"%s\", \"%s\", \"%s\", or be in the form \"%s\"."
msgstr ""
"Das URI-Protokoll wird nicht erkannt. Es sollte mit \"%s\", \"%s\", \"%s\", "
