msgid "The remote URI has leading or trailing whitespace."
msgstr "Die Remote-URI hat führende oder nachfolgende Leerzeichen."

#, php-format
msgid ""
"The remote URI is not formatted correctly. Remote URIs with an explicit "
"protocol should be in the form '%s', not '%s'. The '%s' syntax is only valid "
