msgstr "Unerwartetes erstes \"git upload-pack\"-Protokoll-Frame: erwartet \"<hash> <name>\\0<capabilities>\\n\" oder \"shallow <hash>\\n\", erhalten \"%s\"."

#, php-format
msgid ""
"Unexpected \"git upload-pack\" protocol frame: expected \"<hash> "
"<name>\\n\", or \"shallow <hash>\\n\", got \"%s\"."
msgstr "Unerwartetes \"git upload-pack\"-Protokoll-Frame: erwartet \"<hash> <name>\\n\" oder \"shallow <hash>\\n\", erhalten \"%s\"."

#, php-format
msgid ""
"Mercurial command appears to contain unsafe injected \"--config\" or \"--"
