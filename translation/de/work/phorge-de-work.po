msgstr "Ein neues Mercurial-Repository erstellen."


msgid "Create Subversion Repository"
msgstr "Subversion-Repository erstellen"


msgid "Create a new Subversion repository."
msgstr "Ein neues Subversion-Repository erstellen."


msgid "Shows branches a commit appears on in email."
msgstr "Zeigt Branches, auf denen ein Commit erscheint, in der E-Mail."

#, php-format
msgid "<%s: %s>"
msgstr "<%s: %s>"

msgid "BRANCHES"
msgstr "BRANCHES"

msgid "Merged Commits"
msgstr "Zusammengeführte Commits"

msgid "For merge commits, shows merged changes in email."
msgstr "Zeigt bei Merge-Commits die zusammengeführten Änderungen in der E-Mail."

#, php-format
msgid "This commit merges more than %d changes. Only the first %d are shown.\n"
msgstr ""
"Dieser Commit führt mehr als %d Änderungen zusammen. Es werden nur die "
"ersten %d angezeigt.\n"

msgid "MERGED COMMITS"
msgstr "ZUSAMMENGEFÜHRTE COMMITS"

msgid "Error generating merged commits: "
msgstr "Fehler beim Generieren der zusammengeführten Commits: "

msgid "Shows repository in email."
msgstr "Zeigt das Repository in der E-Mail."

msgid "Shows commit tags in email."
msgstr "Zeigt Commit-Tags in der E-Mail."

msgid "TAGS"
msgstr "TAGS"

#, php-format
msgid "Commit \"%s\" is not a reachable ancestor of \"%s\"."
msgstr "Commit „%s\" ist kein erreichbarer Vorfahre von „%s\"."

#, php-format
msgid "Commit \"%s\" is not a reachable ancestor of any ref."
msgstr "Commit „%s\" ist kein erreichbarer Vorfahre eines Refs."

#, php-format
msgid "No such %s '%s' in repository!"
msgstr "Kein %s '%s' im Repository!"

msgid "Pull only, without discovering commits."
msgstr "Nur pullen, ohne Commits zu ermitteln."

msgid "Do not pull __repository__."
msgstr "Repository __repository__ nicht pullen."

msgid "Pull specific __repositories__ instead of all."
msgstr "Nur bestimmte __repositories__ statt alle pullen."

#, php-format
msgid "Got an update message for repository \"%s\"!"
msgstr "Aktualisierungsnachricht für Repository „%s\" erhalten!"

#, php-format
msgid "Cluster repository (\"%s\") is out of sync on this node (\"%s\")."
msgstr "Cluster-Repository „%s\" ist auf diesem Knoten „%s\" nicht synchron."

#, php-format
msgid ""
"Skipping forced out-of-sync update because the last update was too recent "
"(%s seconds ago)."
msgstr ""
"Erzwungene Out-of-Sync-Aktualisierung wird übersprungen, weil die letzte "
"Aktualisierung zu kürzlich war (vor %s Sekunden)."

#, php-format
msgid "Repository \"%s\" is currently updating."
msgstr "Repository „%s\" wird gerade aktualisiert."

#, php-format
msgid "Repository \"%s\" is already queued."
msgstr "Repository „%s\" ist bereits in der Warteschlange."

#, php-format
msgid ""
"Scheduling repository \"%s\" with an update window of %s second(s). Last "
"update was %s second(s) ago."
msgstr ""
"Repository \"%s\" wird mit einem Aktualisierungsfenster von %s Sekunde(n) "
"eingeplant. Die letzte Aktualisierung war vor %s Sekunde(n)."

#, php-format
msgid "Repository \"%s\" is not due for an update for %s second(s)."
msgstr "Repository „%s\" ist noch %s Sekunde(n) nicht fällig für eine Aktualisierung."

#, php-format
msgid "Scheduling repository \"%s\" for an update (%s seconds overdue)."
msgstr "Repository „%s\" wird für eine Aktualisierung eingeplant (%s Sekunden überfällig)."

#, php-format
msgid "Repository %s is no longer pullable; skipping."
msgstr "Repository %s ist nicht mehr pullbar; wird übersprungen."

#, php-format
msgid "Starting update for repository \"%s\"."
msgstr "Aktualisierung für Repository „%s\" wird gestartet."

#, php-format
msgid ""
"Not enough process slots to schedule the other %s repository(s) for updates "
"yet."
msgstr ""
"Noch nicht genug Prozess-Slots verfügbar, um die übrigen %s Repository(s) "
"für Aktualisierungen einzuplanen."

msgid "Waiting for updates to complete..."
msgstr "Warten auf Abschluss der Aktualisierungen..."

msgid "Interrupted by pending updates!"
msgstr "Durch ausstehende Aktualisierungen unterbrochen!"

#, php-format
msgid "Resolving update for \"%s\"."
msgstr "Aktualisierung für „%s\" wird aufgelöst."

#, php-format
msgid "Error while updating the \"%s\" repository."
msgstr "Fehler beim Aktualisieren des Repositorys „%s\"."

#, php-format
msgid "Unexpected output while updating repository \"%s\": %s"
msgstr "Unerwartete Ausgabe beim Aktualisieren von Repository „%s\": %s"

#, php-format
msgid ""
"Based on activity in repository \"%s\", considering a wait of %s seconds "
"before update."
msgstr ""
"Basierend auf der Aktivität im Repository \"%s\" wird eine Wartezeit von %s "
"Sekunden vor der Aktualisierung in Betracht gezogen."

msgid "No repositories need updates right now, sleeping..."
msgstr "Kein Repository benötigt gerade eine Aktualisierung, schlafe..."

#, php-format
msgid "Sleeping for %s more second(s)..."
msgstr "Warte weitere %s Sekunden..."

msgid "Awakened from sleep by graceful shutdown!"
msgstr "Durch kontrollierten Shutdown aus dem Schlaf geweckt!"

msgid "Awakened from sleep by pending updates!"
msgstr "Durch ausstehende Aktualisierungen aus dem Schlaf geweckt!"

msgid ""
"The chosen callsign or repository short name is already in use by another "
"repository."
msgstr ""
"Das gewählte Rufzeichen oder der gewählte Kurzname des Repositorys wird "
"bereits von einem anderen Repository verwendet."

#, php-format
msgid ""
"Another process is currently discovering repository \"%s\", skipping "
"discovery."
msgstr ""
"Ein anderer Prozess ermittelt gerade Repository \"%s\"; Ermittlung wird "
"übersprungen."

#, php-format
msgid "Unknown VCS '%s'!"
msgstr "Unbekanntes VCS '%s'!"

#, php-format
msgid ""
"Discovered more than %s commits in an empty repository, marking repository "
"as importing."
msgstr ""
"In einem leeren Repository wurden mehr als %s Commits gefunden; Repository "
"wird als importierend markiert."

#, php-format
msgid "Discovering commits in repository \"%s\"."
msgstr "Commits in Repository „%s\" werden ermittelt."


#, php-format
msgid "Examining \"%s\" (%s) at \"%s\"."
msgstr "Prüfe „%s\" (%s) bei „%s\"."

msgid "Skipping, ref is untracked."
msgstr "Überspringe, Ref ist unverfolgt."

msgid "Skipping, HEAD is known."
msgstr "Überspringe, HEAD ist bekannt."

msgid "Skipping, this is not a commit."
msgstr "Überspringe, dies ist kein Commit."

msgid "Looking for new commits."
msgstr "Suche nach neuen Commits."

#, php-format
msgid ""
"Repository \"%s\" does not have a correctly configured remote URI. The "
"remote URI for a Subversion repository MUST point at the repository root. "
"The root for this repository is \"%s\", but the configured URI is \"%s\". To "
"resolve this error, set the remote URI to point at the repository root. If "
"you want to import only part of a Subversion repository, use the \"Import "
"Only\" option."
msgstr ""
"Repository \"%s\" hat keine korrekt konfigurierte Remote-URI. Die Remote-"
"URI für ein Subversion-Repository MUSS auf das Stammverzeichnis des "
"Repositorys zeigen. Das Stammverzeichnis für dieses Repository ist \"%s\", "
"aber die konfigurierte URI ist \"%s\". Um diesen Fehler zu beheben, setze "
"die Remote-URI so, dass sie auf das Stammverzeichnis des Repositorys zeigt. "
"Wenn Du nur einen Teil eines Subversion-Repositorys importieren möchtest, "
"verwende die Option \"Import Only\"."

#, php-format
msgid "Examining branch \"%s\" head \"%s\"."
msgstr "Prüfe Branch „%s\" Head „%s\"."

msgid "Skipping, branch is untracked."
msgstr "Überspringe, Branch ist unverfolgt."

msgid "Skipping, this head is a known commit."
msgstr "Überspringe, dieser Head ist ein bekannter Commit."

#, php-format
msgid "Unable to identify parent \"%s\"!"
msgstr "Elternelement „%s\" konnte nicht identifiziert werden!"

#, php-format
msgid "Repaired commit \"%s\"."
msgstr "Commit „%s\" repariert."

#, php-format
msgid "Unknown repository type \"%s\"!"
msgstr "Unbekannter Repository-Typ „%s\"!"


#, php-format
msgid ""
"Importing %s commit(s) at low priority (\"PRIORITY_IMPORT\") because this "
"repository is still importing."
msgstr ""
"%s Commit(s) werden mit niedriger Priorität (\"PRIORITY_IMPORT\") "
"importiert, weil dieses Repository noch importiert wird."

#, php-format
msgid ""
"Importing %s commits at low priority (\"PRIORITY_IMPORT\") because many "
"commits were discovered at once."
msgstr ""
"%s Commits werden mit niedriger Priorität (\"PRIORITY_IMPORT\") importiert, "
"weil viele Commits auf einmal gefunden wurden."

#, php-format
msgid "Importing %s commit(s) at normal priority (\"PRIORITY_COMMIT\")."
msgstr "%s Commit(s) werden mit normaler Priorität importiert („PRIORITY_COMMIT\")."

msgid "Edit Repository Identity Configurations"
msgstr "Repository-Identitätskonfigurationen bearbeiten"


msgid "This engine is used to edit Repository identities."
msgstr "Diese Engine wird zur Bearbeitung von Repository-Identitäten verwendet."

msgid "Create Identity"
msgstr "Identität erstellen"


#, php-format
msgid "Edit Identity: %s"
msgstr "Identität bearbeiten: %s"


msgid "Identity"
msgstr "Identität"

msgid "Override this identity's assignment."
msgstr "Zuweisung dieser Identität überschreiben."

msgid "This software is running in silent mode; declining to mirror."
msgstr "Die Software läuft im Silent-Modus; Spiegelung wird abgelehnt."

#, php-format
msgid "Exceptions occurred while mirroring the \"%s\" repository."
msgstr "Beim Spiegeln des Repositorys „%s\" sind Ausnahmen aufgetreten."

#, php-format
msgid "Pushing to remote \"%s\"..."
msgstr "Pushe zu Remote „%s\"..."

#, php-format
msgid "Another process is currently updating repository \"%s\", skipping pull."
msgstr ""
"Ein anderer Prozess aktualisiert gerade Repository \"%s\"; Pull wird "
"übersprungen."

#, php-format
msgid ""
"Skipping pull on read-only repository.\n"
"\n"
"%s"
msgstr ""
"Pull auf Nur-Lese-Repository wird übersprungen.\n"
"\n"
"%s"

#, php-format
msgid ""
"Repository \"%s\" is a non-hosted Subversion repository, which does not "
"require a local working copy to be pulled."
msgstr ""
"Repository \"%s\" ist ein nicht gehostetes Subversion-Repository und "
"benötigt keine lokale Arbeitskopie, die gepullt werden müsste."

#, php-format
msgid "Unknown VCS \"%s\"!"
msgstr "Unbekanntes VCS „%s\"!"

#, php-format
msgid "No local path is configured for repository \"%s\"."
msgstr "Für Repository „%s\" ist kein lokaler Pfad konfiguriert."


#, php-format
msgid "Creating a new working copy for repository \"%s\"."
msgstr "Neue Arbeitskopie für Repository „%s\" wird erstellt."


#, php-format
msgid "Updating the working copy for repository \"%s\"."
msgstr "Arbeitskopie für Repository „%s\" wird aktualisiert."


#, php-format
msgid "Pull of '%s' failed: %s"
msgstr "Pull von '%s' fehlgeschlagen: %s"

#, php-format
msgid "Installing commit hook to \"%s\"..."
msgstr "Commit-Hook in „%s\" wird installiert..."

#, php-format
msgid ""
"To add custom hook scripts to this repository, add them to this directory.\n"
"\n"
"%s will run any executables in this directory after running its own checks, "
"as though they were normal hook scripts."
msgstr ""
"Um benutzerdefinierte Hook-Skripte zu diesem Repository hinzuzufügen, lege "
"sie in dieses Verzeichnis.\n"
"\n"
"%s führt alle ausführbaren Dateien in diesem Verzeichnis aus, nachdem die "
"eigenen Prüfungen gelaufen sind, so als wären es normale Hook-Skripte."

#, php-format
msgid ""
"Expected to find a Git repository at \"%s\", but there is an empty directory "
"there. Remove the directory. A daemon will construct the working copy for "
"you."
msgstr ""
"Es wurde erwartet, unter \"%s\" ein Git-Repository zu finden, dort befindet "
"sich aber ein leeres Verzeichnis. Entferne das Verzeichnis. Ein Daemon "
"erstellt die Arbeitskopie für Dich."

#, php-format
msgid ""
"Expected to find a Git repository at \"%s\", but there is a non-repository "
"directory (with other stuff in it) there. Move or remove this directory. A "
"daemon will construct the working copy for you."
msgstr ""
"Es wurde erwartet, unter \"%s\" ein Git-Repository zu finden, dort befindet "
"sich aber ein Verzeichnis, das kein Repository ist (mit anderem Inhalt). "
"Verschiebe oder entferne dieses Verzeichnis. Ein Daemon erstellt die "
"Arbeitskopie für Dich."

#, php-format
msgid ""
"Expected to find a Git repository at \"%s\", but there is a file there "
"instead. Move or remove this file. A daemon will construct the working copy "
"for you."
msgstr ""
"Es wurde erwartet, unter \"%s\" ein Git-Repository zu finden, dort befindet "
"sich aber stattdessen eine Datei. Verschiebe oder entferne diese Datei. Ein "
"Daemon erstellt die Arbeitskopie für Dich."

#, php-format
msgid "Expected to find a git repository at \"%s\", but did not."
msgstr "Erwartet ein Git-Repository bei „%s\", aber keines gefunden."

#, php-format
msgid ""
"Expected to find a Git repository at \"%s\", but the actual Git repository "
"root for this directory is \"%s\". Something is misconfigured. This "
"directory should be writable by the daemons and not inside another Git "
"repository."
msgstr ""
"Es wurde erwartet, unter \"%s\" ein Git-Repository zu finden, aber das "
"tatsächliche Stammverzeichnis des Git-Repositorys für dieses Verzeichnis ist "
"\"%s\". Etwas ist falsch konfiguriert. Dieses Verzeichnis sollte für die "
"Daemons beschreibbar sein und sich nicht innerhalb eines anderen Git-"
"Repositorys befinden."

#, php-format
msgid ""
"Repository working copy at '%s' failed sanity check; destroying and re-"
"cloning. %s"
msgstr ""
"Die Plausibilitätsprüfung der Repository-Arbeitskopie unter '%s' ist "
"fehlgeschlagen; sie wird zerstört und neu geklont. %s"

#, php-format
msgid "Found %s surplus local ref(s) to delete."
msgstr "%s überschüssige lokale Ref(s) zum Löschen gefunden."

#, php-format
msgid "Deleting surplus local ref \"%s\" (\"%s\")."
msgstr "Lösche überschüssigen lokalen Ref „%s\" („%s\")."

msgid "Skipping fetch because local and remote refs are already identical."
msgstr ""
"Fetch wird übersprungen, weil lokale und Remote-Refs bereits identisch sind."

#, php-format
msgid ""
"Refusing to list potentially dangerous ref (\"%s\") beginning with \"-\"."
msgstr ""
"Potenziell gefährlicher Ref (\"%s\"), der mit \"-\" beginnt, wird nicht "
"aufgelistet."

#, php-format
msgid "%s (remote: \"%s\", local: \"%s\")"
msgstr "%s (Remote: „%s\", Lokal: „%s\")"


#, php-format
msgid ""
"Updating repository after detecting ref differences:\n"
"%s"
msgstr ""
"Repository wird nach erkannten Ref-Unterschieden aktualisiert:\n"
"%s"

#, php-format
msgid ""
"You have an old version of Mercurial (%s) which has a severe command "
"injection security vulnerability. The remote URI for this repository (%s) is "
"potentially unsafe. Upgrade Mercurial to at least 3.2.4 to clone it."
msgstr ""
"Du verwendest eine alte Mercurial-Version (%s), die eine schwerwiegende "
"Sicherheitslücke zur Command Injection hat. Die Remote-URI dieses "
"Repositorys (%s) ist potenziell unsicher. Aktualisiere Mercurial auf "
"mindestens 3.2.4, bevor Du es klonst."

msgid "<Response body omitted from Mercurial error message.>"
msgstr "<Antwortinhalt aus Mercurial-Fehlermeldung entfernt.>"

#, php-format
msgid "Installing commit hook config to \"%s\"..."
msgstr "Commit-Hook-Konfiguration in „%s\" wird installiert..."

#, php-format
msgid "Ref %s \"%s\" still points at %s."
msgstr "Ref %s „%s\" zeigt noch auf %s."

#, php-format
msgid "Ref %s \"%s\" no longer points at %s."
msgstr "Ref %s „%s\" zeigt nicht mehr auf %s."

#, php-format
msgid "Ref %s \"%s\" now points at %s."
msgstr "Ref %s „%s\" zeigt jetzt auf %s."

#, php-format
msgid "Ref %s \"%s\" no longer exists."
msgstr "Ref %s „%s\" existiert nicht mehr."

#, php-format
msgid "Unsupported VCS \"%s\"!"
msgstr "Nicht unterstütztes VCS „%s\"!"

#, php-format
msgid ""
"Commit \"%s\" has not been discovered yet! Run discovery before updating "
"refs."
msgstr ""
"Commit \"%s\" wurde noch nicht ermittelt! Führe zuerst die Ermittlung aus, "
"bevor Du Refs aktualisierst."

#, php-format
msgid ""
"Failed to create a new ref cursor (for \"%s\", of type \"%s\", in repository "
"\"%s\") because it collided with an existing cursor, but then failed to load "
"that cursor."
msgstr ""
"Ein neuer Ref-Cursor (für \"%s\", vom Typ \"%s\", im Repository \"%s\") "
"konnte nicht erstellt werden, weil er mit einem vorhandenen Cursor "
"kollidierte; anschließend konnte dieser Cursor aber auch nicht geladen "
"werden."

msgid "Commit Epochs"
msgstr "Commit-Epochen"

#, php-format
msgid "No test data for callsign '%s'. Expected an archive like '%s' in '%s'."
msgstr ""
"Keine Testdaten für Rufzeichen '%s'. Erwartet wurde ein Archiv wie '%s' in "
"'%s'."

#, php-format
msgid "Expected exactly one archive matching callsign '%s', found too many: %s"
msgstr ""
"Es wurde genau ein Archiv erwartet, das zum Rufzeichen '%s' passt, aber es "
"wurden zu viele gefunden: %s"

#, php-format
msgid "Test Repo \"%s\""
msgstr "Repository \"%s\" testen"

#, php-format
msgid "Unexpected infinite loop in %s!"
msgstr "Unerwartete Endlosschleife in %s!"

msgid "Manage the repository graph cache."
msgstr "Repository-Graph-Cache verwalten."

msgid "Specify a commit to look up."
msgstr "Einen Commit zur Suche angeben."

msgid "Specify a path to look up."
msgstr "Einen Pfad zur Suche angeben."

#, php-format
msgid "Specify a commit to look up with `%s`."
msgstr "Einen Commit zur Suche mit `%s` angeben."

#, php-format
msgid "Specify a path to look up with `%s`."
msgstr "Einen Pfad zur Suche mit `%s` angeben."

#, php-format
msgid "Path \"%s\" is not unknown."
msgstr "Pfad „%s\" ist nicht unbekannt."

#, php-format
msgid "Query took %s ms."
msgstr "Abfrage dauerte %s ms."

msgid "Not found in graph cache."
msgstr "Nicht im Graph-Cache gefunden."

msgid "Path not modified in any ancestor commit."
msgstr "Pfad in keinem Vorfahren-Commit geändert."

msgid "Cache returned bogus result!"
msgstr "Cache hat ein ungültiges Ergebnis zurückgegeben!"

#, php-format
msgid "Path was last changed at %s."
msgstr "Pfad wurde zuletzt bei %s geändert."

msgid "Convert existing repositories into cluster repositories."
msgstr "Bestehende Repositories in Cluster-Repositories umwandeln."

msgid "Cluster repository service in Almanac to move repositories into."
msgstr ""
"Cluster-Repository-Dienst in Almanac, in den Repositories verschoben werden "
"sollen."

msgid "Take repositories out of a cluster."
msgstr "Repositories aus einem Cluster entfernen."

msgid "Specify one or more repositories to clusterize."
msgstr "Ein oder mehrere Repositories zum Clustern angeben."

msgid "Specify --service or --remove-service, but not both."
msgstr "„--service\" oder „--remove-service\" angeben, aber nicht beides."

msgid "Specify --service or --remove-service."
msgstr "„--service\" oder „--remove-service\" angeben."

#, php-format
msgid "No repository service \"%s\" exists."
msgstr "Kein Repository-Dienst „%s\" vorhanden."

#, php-format
msgid "Service \"%s\" is actively bound to more than one device (%s)."
msgstr "Dienst „%s\" ist aktiv an mehr als ein Gerät gebunden (%s)."

msgid ""
"If you clusterize a repository onto this service it may be unclear which "
"devices have up-to-date copies of the repository. If so, leader/follower "
"ambiguity will freeze the repository. You may need to manually promote a "
"device to unfreeze it. See \"Ambiguous Leaders\" in the documentation for "
"discussion."
msgstr ""
"Wenn Du ein Repository in diesen Dienst clusterst, ist möglicherweise "
"unklar, welche Geräte aktuelle Kopien des Repositorys haben. In diesem Fall "
"friert die Unklarheit über Leader und Follower das Repository ein. "
"Möglicherweise musst Du ein Gerät manuell zum Leader befördern, um es "
"wieder freizugeben. Siehe \"Ambiguous Leaders\" in der Dokumentation."

#, php-format
msgid "Moved repository \"%s\" to cluster service \"%s\"."
msgstr "Repository „%s\" zu Cluster-Dienst „%s\" verschoben."

#, php-format
msgid "Removed repository \"%s\" from cluster service."
msgstr "Repository „%s\" aus Cluster-Dienst entfernt."

msgid "Discover commits in __repository__."
msgstr "Commits in Repository __repository__ ermitteln."

msgid "Show additional debugging information."
msgstr "Zusätzliche Debugging-Informationen anzeigen."

msgid ""
"Discover all commits, even if they are ancestors of known commits. This can "
"repair gaps in repository history."
msgstr ""
"Alle Commits ermitteln, auch wenn sie Vorfahren bereits bekannter Commits "
"sind. Dadurch können Lücken in der Repository-Historie repariert werden."

msgid "Specify one or more repositories to discover."
msgstr "Ein oder mehrere Repositories zur Ermittlung angeben."

#, php-format
msgid "Discovering \"%s\"..."
msgstr "„%s\" wird ermittelt..."

msgid "Write hints about unusual (rewritten or unreadable) commits."
msgstr "Hinweise über ungewöhnliche (umgeschriebene oder unlesbare) Commits schreiben."

msgid "Reading list of hints from stdin..."
msgstr "Hinweisliste aus stdin wird gelesen..."

msgid "Failed to read stdin."
msgstr "Stdin konnte nicht gelesen werden."


#, php-format
msgid "Expected a list of hints in JSON format: %s"
msgstr "Eine Hinweisliste im JSON-Format erwartet: %s"

#, php-format
msgid ""
"Each item in the list of hints should be a JSON object, but the item at "
"index \"%s\" is not."
msgstr ""
"Jeder Eintrag in der Hinweisliste sollte ein JSON-Objekt sein, aber der "
"Eintrag an Index \"%s\" ist keines."

#, php-format
msgid "Unexpected hint format at index \"%s\": %s"
msgstr "Unerwartetes Hinweisformat bei Index „%s\": %s"

#, php-format
msgid ""
"Repository identifier \"%s\" (in hint at index \"%s\") does not identify a "
"valid repository."
msgstr ""
"Der Repository-Bezeichner \"%s\" (im Hinweis an Index \"%s\") kennzeichnet "
"kein gültiges Repository."

#, php-format
msgid "Updated hint for \"%s\"."
msgstr "Hinweis für „%s\" aktualisiert."


msgid "Show commits in __repository__ which are still importing."
msgstr "Commits in Repository __repository__ anzeigen, die noch importiert werden."

msgid "Show simpler output."
msgstr "Einfachere Ausgabe anzeigen."

msgid "Specify one or more repositories to find importing commits for."
msgstr "Ein oder mehrere Repositories angeben, um importierende Commits zu finden."

msgid "No importing commits found."
msgstr "Keine importierenden Commits gefunden."

msgid "List repository local paths."
msgstr "Lokale Repository-Pfade auflisten."

msgid "There are no repositories."
msgstr "Es gibt keine Repositories."

msgid "Show a list of repositories."
msgstr "Eine Liste der Repositories anzeigen."

msgid "Temporarily lock clustered repositories to perform maintenance."
msgstr "Geclusterte Repositories vorübergehend für Wartung sperren."

msgid "Specify one or more repositories to lock."
msgstr "Ein oder mehrere Repositories zum Sperren angeben."

#, php-format
msgid ""
"Unable to lock repository \"%s\": only hosted repositories may be locked."
msgstr ""
"Repository \"%s\" kann nicht gesperrt werden: Nur gehostete Repositories "
"dürfen gesperrt werden."

#, php-format
msgid ""
"Unable to lock repository \"%s\": only repositories that support clustering "
"may be locked."
msgstr ""
"Repository \"%s\" kann nicht gesperrt werden: Nur Repositories, die "
"Clustering unterstützen, dürfen gesperrt werden."

#, php-format
msgid ""
"Unable to lock repository \"%s\": only clustered repositories may be locked."
msgstr ""
"Repository \"%s\" kann nicht gesperrt werden: Nur geclusterte Repositories "
"dürfen gesperrt werden."

msgid "These repositories will be locked:"
msgstr "Diese Repositories werden gesperrt:"


msgid ""
"While the lock is held: users will be unable to write to this repository, "
"and you may safely perform working copy maintenance on this node in another "
"terminal window."
msgstr ""
"Solange die Sperre gehalten wird, können Benutzer nicht in dieses "
"Repository schreiben, und Du kannst in einem anderen Terminalfenster auf "
"diesem Knoten gefahrlos Wartung an der Arbeitskopie durchführen."

msgid "Lock repositories and begin maintenance?"
msgstr "Repositories sperren und Wartung beginnen?"

msgid ""
"Repositories are now locked. You may begin maintenance in another terminal "
