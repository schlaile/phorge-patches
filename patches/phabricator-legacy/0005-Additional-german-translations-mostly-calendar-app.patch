+msgstr ""
+
+#: applications/config/option/PhabricatorCoreConfigOptions.php:295
+#: applications/config/option/PhabricatorSecurityConfigOptions.php:319
+#, php-format
+msgid "Config option '%s' is invalid. The URI must NOT have a path, e.g. '%s' is OK, but '%s' is not. Phabricator must be installed on an entire domain; it can not be installed on a path."
+msgstr ""
