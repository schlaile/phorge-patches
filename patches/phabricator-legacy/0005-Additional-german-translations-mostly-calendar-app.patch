+#: applications/config/option/PhabricatorSecurityConfigOptions.php:307
+#, php-format
+msgid "Config option '%s' is invalid. The URI must contain a dot ('.'), like '%s', not just a bare name like '%s'. Some web browsers will not set cookies on domains with no TLD."
+msgstr ""
