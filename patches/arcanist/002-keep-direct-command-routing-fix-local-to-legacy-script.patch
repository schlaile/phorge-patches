From 29e20620fcc18c65fd1b280e92dbeaf8431c661d Mon Sep 17 00:00:00 2001
From: Alicia Codex <alicia@schlaile.de>
Date: Sun, 29 Mar 2026 15:19:13 +0200
Subject: [PATCH] Keep legacy launcher fix local to scripts/arcanist.php

---
 scripts/arcanist.php            |  4 ----
 src/runtime/ArcanistRuntime.php | 21 ++++-----------------
 2 files changed, 4 insertions(+), 21 deletions(-)

diff --git a/scripts/arcanist.php b/scripts/arcanist.php
index e1ee4f31..8e95b4b1 100755
--- a/scripts/arcanist.php
+++ b/scripts/arcanist.php
@@ -49,10 +49,6 @@ function arcanist_adjust_php_include_path() {
 arcanist_adjust_php_include_path();
 
 function arcanist_should_use_runtime($help, $workflow) {
-  if (getenv(ArcanistRuntime::ENV_LEGACY_FALLTHROUGH)) {
-    return false;
-  }
-
   if ($help) {
     return true;
   }
diff --git a/src/runtime/ArcanistRuntime.php b/src/runtime/ArcanistRuntime.php
index 938c8299..b1b9cd11 100644
--- a/src/runtime/ArcanistRuntime.php
+++ b/src/runtime/ArcanistRuntime.php
@@ -2,8 +2,6 @@
 
 final class ArcanistRuntime {
 
-  const ENV_LEGACY_FALLTHROUGH = 'ARCANIST_RUNTIME_LEGACY_FALLTHROUGH';
-
   private $workflows;
   private $logEngine;
   private $lastInterruptTime;
@@ -232,21 +230,10 @@ final class ArcanistRuntime {
     $arcanist_root = dirname($arcanist_root);
     $bin = $arcanist_root.'/scripts/arcanist.php';
 
-    $old_fallthrough = getenv(self::ENV_LEGACY_FALLTHROUGH);
-    putenv(self::ENV_LEGACY_FALLTHROUGH.'=1');
-
-    try {
-      $err = phutil_passthru(
-        'php -f %R -- %Ls',
-        $bin,
-        array_slice($argv, 1));
-    } finally {
-      if ($old_fallthrough === false) {
-        putenv(self::ENV_LEGACY_FALLTHROUGH);
-      } else {
-        putenv(self::ENV_LEGACY_FALLTHROUGH.'='.$old_fallthrough);
-      }
-    }
+    $err = phutil_passthru(
+      'php -f %R -- %Ls',
+      $bin,
+      array_slice($argv, 1));
 
     return $err;
   }
-- 
2.47.3

