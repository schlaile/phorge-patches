From aa67ee212ada20676ce0f7296b02f0d7b7d2a1a0 Mon Sep 17 00:00:00 2001
From: Alicia Codex <alicia@schlaile.de>
Date: Sun, 29 Mar 2026 14:32:04 +0200
Subject: [PATCH] Fix PHP 8 error handler callback signature

---
 src/error/PhutilErrorHandler.php | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/src/error/PhutilErrorHandler.php b/src/error/PhutilErrorHandler.php
index 76a8450..b2a8138 100644
--- a/src/error/PhutilErrorHandler.php
+++ b/src/error/PhutilErrorHandler.php
@@ -176,11 +176,11 @@ final class PhutilErrorHandler extends Phobject {
    * @param string Error message.
    * @param string File where the error occurred.
    * @param int Line on which the error occurred.
-   * @param wild Error context information.
+   * @param wild|null Error context information, when available.
    * @return void
    * @task internal
    */
-  public static function handleError($num, $str, $file, $line, $ctx) {
+  public static function handleError($num, $str, $file, $line, $ctx = null) {
 
     foreach (self::$traps as $trap) {
       $trap->addError($num, $str, $file, $line, $ctx);
-- 
2.47.3

